# ─────────────────────────────────────────────
# Regulome — Environment Variables
# Copy to .env.local and fill in values
# ─────────────────────────────────────────────

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://regulome.io

# ── Database (Neon) ────────────────────────────
# Get from: https://console.neon.tech → Connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Auth (NextAuth / Auth.js v5) ───────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=
# Google OAuth (optional — for provider dashboard)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── PostHog Analytics ─────────────────────────
# Get from: https://us.posthog.com → Project settings
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Stripe ────────────────────────────────────
# Get from: https://dashboard.stripe.com → API keys
STRIPE_SECRET_KEY=sk_live_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# Webhook secret: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Anthropic (Claude API) ────────────────────
# Get from: https://console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-xxx

# ── Loops (Newsletter) ────────────────────────
# Get from: https://app.loops.so → Settings → API
LOOPS_API_KEY=
# Get from: https://app.loops.so → Audience → Lists (the "regulome.io Newsletter" list ID)
LOOPS_LIST_ID=
# Get from: https://app.loops.so → Campaigns → Transactional (welcome email template ID)
LOOPS_TRANSACTIONAL_ID=

# ── Resend (Email — leads/internal) ───────────
# Get from: https://resend.com → API keys
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=hello@aicompliancehub.com

# ── Gemini (Google AI) ────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# Used by scripts/generate-blog-images.ts to create cover images
GEMINI_API_KEY=

# ── Vercel (auto-injected in prod) ────────────
# VERCEL_URL is set automatically by Vercel
